select DISTINCT     TIPO_DOCUMENTO,
 KEY_ID, 
    CASE
        WHEN VALOR_INGRESOS < 1000 THEN NULL
        ELSE VALOR_INGRESOS
    END AS VALOR_INGRESOS,

    CASE
        WHEN VALOR_EGRESOS < 1000 THEN NULL
        ELSE VALOR_EGRESOS
    END AS VALOR_EGRESOS,

    CASE
        WHEN VALOR_ACTIVOS < 1000 THEN NULL
        ELSE VALOR_ACTIVOS
    END AS VALOR_ACTIVOS,

    CASE
        WHEN VALOR_PASIVOS < 1000 THEN NULL
        ELSE VALOR_PASIVOS
    END AS VALOR_PASIVOS,

    CASE
        WHEN VALOR_PATRIMONIO < 1000 THEN NULL
        ELSE VALOR_PATRIMONIO
    END AS VALOR_PATRIMONI
    
    
FROM `sb-ecosistemaanalitico-lago.seguros_bolivar.t_trazabilidad_formatos_servicios_marcas`

WHERE TIPO_DOCUMENTO IN ('NT', 'NE')
and  
(VALOR_ACTIVOS <= 1000 or VALOR_ACTIVOS is null)
AND (VALOR_PASIVOS <= 1000 or VALOR_PASIVOS is null)
AND (VALOR_INGRESOS <= 1000 or VALOR_INGRESOS is null)
AND(VALOR_EGRESOS <= 1000 or VALOR_EGRESOS is null)
