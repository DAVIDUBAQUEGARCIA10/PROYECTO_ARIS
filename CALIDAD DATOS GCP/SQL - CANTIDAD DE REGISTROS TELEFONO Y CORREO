    WITH 
    CORREOS_UNIFICADOS AS (
      SELECT 
        n.numero_documento,
        n.tipdoc_codigo AS tipo_documento,
        MIN(mcn.descripcion) AS correo_unificado
      FROM naturales n
      JOIN medios_comunicacion mcn 
        ON mcn.nat_secuencia = n.secuencia
      JOIN tipos_medios_comunicacion tmcn 
        ON tmcn.secuencia = mcn.tipmedcom_codigo
      WHERE tmcn.descripcion LIKE '%EMAIL%'
        AND mcn.descripcion LIKE '%@%'
      GROUP BY n.numero_documento, n.tipdoc_codigo
    
      UNION
    
      SELECT 
        j.numero_documento,
        j.tipdoc_codigo AS tipo_documento,
        MIN(mcj.descripcion) AS correo_unificado
      FROM juridicos j
      JOIN medios_comunicacion mcj 
        ON mcj.jur_secuencia = j.secuencia
      JOIN tipos_medios_comunicacion tmcj 
        ON tmcj.secuencia = mcj.tipmedcom_codigo
      WHERE tmcj.descripcion LIKE '%EMAIL%'
        AND mcj.descripcion LIKE '%@%'
      GROUP BY j.numero_documento, j.tipdoc_codigo
    ),
    
    CELULAR_UNIFICADO AS (
      SELECT
        x.tipo_documento,
        x.numero_documento,
        x.num_limpio AS celular_unificado
      FROM (
        SELECT
          base.tipo_documento,
          base.numero_documento,
          base.num_limpio,
          ROW_NUMBER() OVER (
            PARTITION BY base.tipo_documento, base.numero_documento
            ORDER BY LENGTH(base.num_limpio) DESC,
                     TO_NUMBER(base.num_limpio) DESC NULLS LAST
          ) AS rn
        FROM (
    
          SELECT
            j.tipdoc_codigo AS tipo_documento,
            j.numero_documento,
            CASE
              WHEN REGEXP_LIKE(REGEXP_REPLACE(TRIM(mcn.descripcion), '[^0-9]', ''), '^[0-9]{10}$')
              THEN REGEXP_REPLACE(TRIM(mcn.descripcion), '[^0-9]', '')
              WHEN REGEXP_LIKE(REGEXP_REPLACE(TRIM(mcn.descripcion), '[^0-9]', ''), '^[0-9]{7}$')
              THEN REGEXP_REPLACE(TRIM(mcn.descripcion), '[^0-9]', '')
            END AS num_limpio
          FROM juridicos j
          JOIN naturales n
            ON n.numero_documento = j.numero_documento_representante
           AND n.tipdoc_codigo = j.tipdoc_codigo_identificado_por
          LEFT JOIN medios_comunicacion mcn
            ON mcn.nat_secuencia = n.secuencia
          WHERE mcn.tipmedcom_codigo IN (
            1,2,3,4,5,10,11,13,22,40,41,42,62,65,68,69,71,73,75,78
          )
    
          UNION ALL
    
          SELECT
            j.tipdoc_codigo AS tipo_documento,
            j.numero_documento,
            CASE
              WHEN REGEXP_LIKE(REGEXP_REPLACE(TRIM(mcj.descripcion), '[^0-9]', ''), '^[0-9]{10}$')
              THEN REGEXP_REPLACE(TRIM(mcj.descripcion), '[^0-9]', '')
              WHEN REGEXP_LIKE(REGEXP_REPLACE(TRIM(mcj.descripcion), '[^0-9]', ''), '^[0-9]{7}$')
              THEN REGEXP_REPLACE(TRIM(mcj.descripcion), '[^0-9]', '')
            END AS num_limpio
          FROM juridicos j
          LEFT JOIN medios_comunicacion mcj
            ON mcj.jur_secuencia = j.secuencia
          LEFT JOIN tipos_medios_comunicacion tmcj
            ON tmcj.secuencia = mcj.tipmedcom_codigo
          WHERE tmcj.secuencia IN (
            1,2,3,4,5,10,11,13,22,40,41,42,62,65,68,69,71,73,75,78
          )
    
          UNION ALL
    
          SELECT 
            n.tipdoc_codigo AS tipo_documento,
            n.numero_documento,
            CASE 
              WHEN REGEXP_LIKE(REGEXP_REPLACE(TRIM(mcn.descripcion), '[^0-9]', ''), '^[0-9]{10}$')
              THEN REGEXP_REPLACE(TRIM(mcn.descripcion), '[^0-9]', '')
              WHEN REGEXP_LIKE(REGEXP_REPLACE(TRIM(mcn.descripcion), '[^0-9]', ''), '^[0-9]{7}$')
              THEN REGEXP_REPLACE(TRIM(mcn.descripcion), '[^0-9]', '')
            END AS num_limpio
          FROM naturales n
          JOIN medios_comunicacion mcn
            ON mcn.nat_secuencia = n.secuencia
          JOIN tipos_medios_comunicacion tmcn
            ON tmcn.secuencia = mcn.tipmedcom_codigo
          WHERE tmcn.secuencia IN (
            1,2,3,4,5,10,11,13,22,40,41,42,62,65,68,69,71,73,75,78
          )
    
        ) base
        WHERE base.num_limpio IS NOT NULL
      ) x
      WHERE x.rn = 1
    ),
    
    BASE_CLIENTES AS (
      SELECT DISTINCT
        m.exrf_cod_tip_doc AS tipo_documento,
        m.exrf_num_id_cliente AS numero_documento,
    
        CASE 
          WHEN m.exrf_cod_tip_doc IN ('NT', 'NE') 
          THEN 'PERSONA JURIDICA'
          ELSE 'PERSONA NATURAL'
        END AS tipo_persona_agrupado,
    
        CASE 
          WHEN cu2.celular_unificado IS NOT NULL 
          THEN cu2.celular_unificado
          ELSE NULLIF(TRIM(m.exrf_telefono_residencia), '')
        END AS telefono_contacto,
    
        NULLIF(TRIM(cu.correo_unificado), '') AS correo
    
      FROM dc_ext_revisoria_fiscal m
    
      LEFT JOIN CORREOS_UNIFICADOS cu 
        ON cu.numero_documento = m.exrf_num_id_cliente
       AND cu.tipo_documento = m.exrf_cod_tip_doc
    
      LEFT JOIN CELULAR_UNIFICADO cu2
        ON cu2.numero_documento = m.exrf_num_id_cliente
       AND cu2.tipo_documento = m.exrf_cod_tip_doc
    
      WHERE m.exrf_cod_tip_doc IS NOT NULL
        AND m.exrf_num_id_cliente IS NOT NULL
    )
    
    SELECT
      tipo_persona_agrupado,
      COUNT(*) AS cantidad_clientes,
    
      SUM(
        CASE 
          WHEN telefono_contacto IS NULL 
            OR correo IS NULL 
          THEN 1 
          ELSE 0 
        END
      ) AS cantidad_clientes_con_incompletitud,
    
      SUM(
        CASE 
          WHEN telefono_contacto IS NULL THEN 1 
          ELSE 0 
        END
      ) AS clientes_sin_telefono,
    
      SUM(
        CASE 
          WHEN correo IS NULL THEN 1 
          ELSE 0 
        END
      ) AS clientes_sin_correo
    
    FROM BASE_CLIENTES
    GROUP BY tipo_persona_agrupado
    ORDER BY tipo_persona_agrupado;
