WITH base AS (

    SELECT DISTINCT
        TIPO_DOCUMENTO,
        KEY_ID

    FROM `sb-ecosistemaanalitico-lago.seguros_bolivar.t_trazabilidad_formatos_servicios_marcas`

    WHERE TIPO_DOCUMENTO IN ('NT', 'NE')
),

bolivar_detalle AS (

    SELECT
        TIPO_DOCUMENTO,
        KEY_ID,
        CODIGO_TIPO_DOCUMENTO_CONTACTO,
        KEY_ID_CONTACTO,
        PORCENTAJE_PARTICIPACION,
        FECHA_CREACION

    FROM `sb-ecosistemaanalitico-lago.seguros_bolivar.t_beneficiario_final`

    WHERE PORCENTAJE_PARTICIPACION > 0
      AND MARCA_REGISTRO_ACTIVO = 'A'
),

beneficiarios_bolivar_original AS (

    SELECT
        TIPO_DOCUMENTO,
        KEY_ID,

        SUM(PORCENTAJE_PARTICIPACION)
            AS SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR_ORIGINAL,

        COUNT(DISTINCT CONCAT(
            CAST(CODIGO_TIPO_DOCUMENTO_CONTACTO AS STRING),
            '-',
            CAST(KEY_ID_CONTACTO AS STRING)
        )) AS CANTIDAD_ACCIONISTAS_BOLIVAR_ORIGINAL

    FROM bolivar_detalle

    GROUP BY
        TIPO_DOCUMENTO,
        KEY_ID
),

bolivar_por_fecha AS (

    SELECT
        TIPO_DOCUMENTO,
        KEY_ID,
        DATE(FECHA_CREACION) AS FECHA_CREACION_REFERENCIA,

        SUM(PORCENTAJE_PARTICIPACION)
            AS SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR_OPTIMIZADA,

        COUNT(DISTINCT CONCAT(
            CAST(CODIGO_TIPO_DOCUMENTO_CONTACTO AS STRING),
            '-',
            CAST(KEY_ID_CONTACTO AS STRING)
        )) AS CANTIDAD_ACCIONISTAS_BOLIVAR_OPTIMIZADA

    FROM bolivar_detalle

    GROUP BY
        TIPO_DOCUMENTO,
        KEY_ID,
        DATE(FECHA_CREACION)

    HAVING SUM(PORCENTAJE_PARTICIPACION) BETWEEN 80 AND 100
),

bolivar_fecha_optima AS (

    SELECT
        *

    FROM bolivar_por_fecha

    QUALIFY ROW_NUMBER() OVER (
        PARTITION BY TIPO_DOCUMENTO, KEY_ID
        ORDER BY FECHA_CREACION_REFERENCIA DESC
    ) = 1
),

beneficiarios_bolivar AS (

    SELECT
        bo.TIPO_DOCUMENTO,
        bo.KEY_ID,

        bo.SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR_ORIGINAL,
        bo.CANTIDAD_ACCIONISTAS_BOLIVAR_ORIGINAL,

        bf.FECHA_CREACION_REFERENCIA AS FECHA_OPTIMIZACION_BOLIVAR,
        bf.SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR_OPTIMIZADA,
        bf.CANTIDAD_ACCIONISTAS_BOLIVAR_OPTIMIZADA,

        CASE
            WHEN bo.SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR_ORIGINAL > 100
             AND bf.SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR_OPTIMIZADA IS NOT NULL
                THEN bf.SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR_OPTIMIZADA
            ELSE bo.SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR_ORIGINAL
        END AS SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR,

        CASE
            WHEN bo.SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR_ORIGINAL > 100
             AND bf.SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR_OPTIMIZADA IS NOT NULL
                THEN bf.CANTIDAD_ACCIONISTAS_BOLIVAR_OPTIMIZADA
            ELSE bo.CANTIDAD_ACCIONISTAS_BOLIVAR_ORIGINAL
        END AS CANTIDAD_ACCIONISTAS_BOLIVAR,

        CASE
            WHEN bo.SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR_ORIGINAL > 100
             AND bf.SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR_OPTIMIZADA IS NOT NULL
                THEN 'BOLIVAR_OPTIMIZADO_FECHA'

            WHEN bo.SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR_ORIGINAL > 100
                THEN 'BOLIVAR_MAYOR_100_SIN_OPTIMIZAR'

            WHEN bo.SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR_ORIGINAL BETWEEN 80 AND 100
                THEN 'BOLIVAR_VALIDO_80_A_100'

            WHEN bo.SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR_ORIGINAL BETWEEN 1 AND 79
                THEN 'BOLIVAR_1_A_79'

            WHEN bo.SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR_ORIGINAL = 0
                THEN 'BOLIVAR_0'

            ELSE 'BOLIVAR_NULL'
        END AS ESTADO_BOLIVAR

    FROM beneficiarios_bolivar_original bo

    LEFT JOIN bolivar_fecha_optima bf
        ON bo.TIPO_DOCUMENTO = bf.TIPO_DOCUMENTO
       AND bo.KEY_ID = bf.KEY_ID
),

beneficiarios_davivienda AS (

    SELECT
        a.TIPO_DOCUMENTO_CLIENTE AS TIPO_DOCUMENTO,

        LPAD(CAST(a.KEY_ID_CLIENTE AS STRING), 9, '0') AS KEY_ID,

        SUM(a.PORCENTAJE_PARTICIPACION_SOCIO) / 100
            AS SUMATORIA_COMPOSICION_ACCIONARIA_DAVIVIENDA,

        COUNT(DISTINCT CONCAT(
            CAST(a.TIPO_DOCUMENTO_RELACIONADO AS STRING),
            '-',
            CAST(a.KEY_ID_RELACIONADO AS STRING)
        )) AS CANTIDAD_ACCIONISTAS_DAVIVIENDA

    FROM `sb-ecosistemaanalitico-lago.davivienda.t_individuos_relacionados_pn_pj` AS a

    WHERE a.PORCENTAJE_PARTICIPACION_SOCIO > 0
      AND a.ESTADO_DATO = 'VIGENTE'

    GROUP BY
        a.TIPO_DOCUMENTO_CLIENTE,
        LPAD(CAST(a.KEY_ID_CLIENTE AS STRING), 9, '0')
),

final AS (

    SELECT DISTINCT
        b.TIPO_DOCUMENTO,
        b.KEY_ID,

        bb.SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR_ORIGINAL,
        bb.CANTIDAD_ACCIONISTAS_BOLIVAR_ORIGINAL,

        bb.SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR_OPTIMIZADA,
        bb.CANTIDAD_ACCIONISTAS_BOLIVAR_OPTIMIZADA,
        bb.FECHA_OPTIMIZACION_BOLIVAR,

        bb.SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR,
        bb.CANTIDAD_ACCIONISTAS_BOLIVAR,
        bb.ESTADO_BOLIVAR,

        bd.SUMATORIA_COMPOSICION_ACCIONARIA_DAVIVIENDA,
        bd.CANTIDAD_ACCIONISTAS_DAVIVIENDA

    FROM base b

    LEFT JOIN beneficiarios_bolivar bb
        ON b.TIPO_DOCUMENTO = bb.TIPO_DOCUMENTO
       AND b.KEY_ID = bb.KEY_ID

    LEFT JOIN beneficiarios_davivienda bd
        ON b.TIPO_DOCUMENTO = bd.TIPO_DOCUMENTO
       AND b.KEY_ID = bd.KEY_ID
),

base_final AS (

    SELECT
        *,

        CASE
            WHEN (
                    SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR IS NULL
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR = 0
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR BETWEEN 1 AND 79
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR > 100
                 )
             AND SUMATORIA_COMPOSICION_ACCIONARIA_DAVIVIENDA BETWEEN 80 AND 100
                THEN SUMATORIA_COMPOSICION_ACCIONARIA_DAVIVIENDA

            ELSE SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR
        END AS SUMATORIA_COMPOSICION_ACCIONARIA_FINAL,

        CASE
            WHEN (
                    SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR IS NULL
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR = 0
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR BETWEEN 1 AND 79
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR > 100
                 )
             AND SUMATORIA_COMPOSICION_ACCIONARIA_DAVIVIENDA BETWEEN 80 AND 100
                THEN CANTIDAD_ACCIONISTAS_DAVIVIENDA

            ELSE CANTIDAD_ACCIONISTAS_BOLIVAR
        END AS CANTIDAD_ACCIONISTAS_FINAL,

        CASE
            WHEN (
                    SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR IS NULL
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR = 0
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR BETWEEN 1 AND 79
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR > 100
                 )
             AND SUMATORIA_COMPOSICION_ACCIONARIA_DAVIVIENDA BETWEEN 80 AND 100
                THEN 'APORTE_DAVIVIENDA'

            ELSE 'DIRECTO_TERCEROS_BOLIVAR'
        END AS ORIGEN_RESULTADO,

        CASE
            WHEN (
                    SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR IS NULL
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR = 0
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR BETWEEN 1 AND 79
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR > 100
                 )
             AND SUMATORIA_COMPOSICION_ACCIONARIA_DAVIVIENDA BETWEEN 80 AND 100
                THEN 'REEMPLAZADO_CON_DAVIVIENDA'

            WHEN ESTADO_BOLIVAR = 'BOLIVAR_OPTIMIZADO_FECHA'
                THEN 'OPTIMIZADO_BOLIVAR_POR_FECHA'

            WHEN SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR > 100
                THEN 'MAYOR_100'

            WHEN SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR BETWEEN 80 AND 100
                THEN 'VALIDO_80_A_100'

            WHEN SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR BETWEEN 1 AND 79
                THEN 'RANGO_1_A_79'

            WHEN SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR IS NULL
              OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR = 0
                THEN 'RANGO_0_O_NULL'

            ELSE 'SIN_CLASIFICAR'
        END AS ESTADO_RESULTADO_FINAL

    FROM final
)

SELECT
    *

FROM base_final
where ESTADO_RESULTADO_FINAL in ("SIN_CLASIFICAR","RANGO_0_O_NULL","RANGO_1_A_79","MAYOR_100")
