WITH base AS (

    SELECT DISTINCT
        TIPO_DOCUMENTO,
        KEY_ID

    FROM `sb-ecosistemaanalitico-lago.seguros_bolivar.t_trazabilidad_formatos_servicios_marcas`

    WHERE TIPO_DOCUMENTO IN ('NT', 'NE')
),

beneficiarios_bolivar AS (

    SELECT
        TIPO_DOCUMENTO,
        KEY_ID,

        SUM(PORCENTAJE_PARTICIPACION)
            AS SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR,

        COUNT(DISTINCT CONCAT(
            CAST(CODIGO_TIPO_DOCUMENTO_CONTACTO AS STRING),
            '-',
            CAST(KEY_ID_CONTACTO AS STRING)
        )) AS CANTIDAD_ACCIONISTAS_BOLIVAR

    FROM `sb-ecosistemaanalitico-lago.seguros_bolivar.t_beneficiario_final`

    WHERE PORCENTAJE_PARTICIPACION > 0
      AND MARCA_REGISTRO_ACTIVO = 'A'

    GROUP BY
        TIPO_DOCUMENTO,
        KEY_ID
),

beneficiarios_davivienda AS (

    SELECT
        a.TIPO_DOCUMENTO_CLIENTE AS TIPO_DOCUMENTO,

        LPAD(CAST(a.KEY_ID_CLIENTE AS STRING), 9, '0')
            AS KEY_ID,

        SUM(a.PORCENTAJE_PARTICIPACION_SOCIO) / 100
            AS SUMATORIA_COMPOSICION_ACCIONARIA_DAVIVIENDA,

        COUNT(DISTINCT CONCAT(
            CAST(a.TIPO_DOCUMENTO_RELACIONADO AS STRING),
            '-',
            CAST(a.KEY_ID_RELACIONADO AS STRING)
        )) AS CANTIDAD_ACCIONISTAS_DAVIVIENDA

    FROM `sb-ecosistemaanalitico-lago.davivienda.t_individuos_relacionados_pn_pj` AS a

    WHERE a.PORCENTAJE_PARTICIPACION_SOCIO > 0
      AND a.ESTADO_DATO = 'VIGENTE'

    GROUP BY
        a.TIPO_DOCUMENTO_CLIENTE,
        LPAD(CAST(a.KEY_ID_CLIENTE AS STRING), 9, '0')
),

final AS (

    SELECT DISTINCT
        b.TIPO_DOCUMENTO,
        b.KEY_ID,

        bb.SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR,
        bb.CANTIDAD_ACCIONISTAS_BOLIVAR,

        bd.SUMATORIA_COMPOSICION_ACCIONARIA_DAVIVIENDA,
        bd.CANTIDAD_ACCIONISTAS_DAVIVIENDA

    FROM base b

    LEFT JOIN beneficiarios_bolivar bb
        ON b.TIPO_DOCUMENTO = bb.TIPO_DOCUMENTO
       AND b.KEY_ID = bb.KEY_ID

    LEFT JOIN beneficiarios_davivienda bd
        ON b.TIPO_DOCUMENTO = bd.TIPO_DOCUMENTO
       AND b.KEY_ID = bd.KEY_ID
),

final_marcada AS (

    SELECT
        TIPO_DOCUMENTO,
        KEY_ID,

        CASE
            WHEN (
                    SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR IS NULL
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR = 0
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR BETWEEN 1 AND 79
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR > 100
                 )
             AND SUMATORIA_COMPOSICION_ACCIONARIA_DAVIVIENDA BETWEEN 80 AND 100
                THEN 'APORTE_DAVIVIENDA'

            ELSE 'DIRECTO_TERCEROS_BOLIVAR'
        END AS ORIGEN_RESULTADO,

        CASE
            WHEN (
                    SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR IS NULL
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR = 0
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR BETWEEN 1 AND 79
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR > 100
                 )
             AND SUMATORIA_COMPOSICION_ACCIONARIA_DAVIVIENDA BETWEEN 80 AND 100
                THEN SUMATORIA_COMPOSICION_ACCIONARIA_DAVIVIENDA

            ELSE SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR
        END AS SUMATORIA_COMPOSICION_ACCIONARIA_FINAL,

        CASE
            WHEN (
                    SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR IS NULL
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR = 0
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR BETWEEN 1 AND 79
                    OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR > 100
                 )
             AND SUMATORIA_COMPOSICION_ACCIONARIA_DAVIVIENDA BETWEEN 80 AND 100
                THEN CANTIDAD_ACCIONISTAS_DAVIVIENDA

            ELSE CANTIDAD_ACCIONISTAS_BOLIVAR
        END AS CANTIDAD_ACCIONISTAS_FINAL

    FROM final

    QUALIFY ROW_NUMBER() OVER (
        PARTITION BY TIPO_DOCUMENTO, KEY_ID
        ORDER BY
            CASE
                WHEN (
                        SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR IS NULL
                        OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR = 0
                        OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR BETWEEN 1 AND 79
                        OR SUMATORIA_COMPOSICION_ACCIONARIA_BOLIVAR > 100
                     )
                 AND SUMATORIA_COMPOSICION_ACCIONARIA_DAVIVIENDA BETWEEN 80 AND 100
                    THEN 1
                ELSE 2
            END
    ) = 1
)

SELECT
    ORIGEN_RESULTADO,

    COUNT(DISTINCT CONCAT(
        CAST(TIPO_DOCUMENTO AS STRING),
        '-',
        CAST(KEY_ID AS STRING)
    )) AS TOTAL_REGISTROS,

    COUNT(DISTINCT IF(
        SUMATORIA_COMPOSICION_ACCIONARIA_FINAL IS NULL
        OR SUMATORIA_COMPOSICION_ACCIONARIA_FINAL = 0,
        CONCAT(CAST(TIPO_DOCUMENTO AS STRING), '-', CAST(KEY_ID AS STRING)),
        NULL
    )) AS RANGO_0_O_NULL,

    COUNT(DISTINCT IF(
        SUMATORIA_COMPOSICION_ACCIONARIA_FINAL BETWEEN 1 AND 79,
        CONCAT(CAST(TIPO_DOCUMENTO AS STRING), '-', CAST(KEY_ID AS STRING)),
        NULL
    )) AS RANGO_1_A_79,

    COUNT(DISTINCT IF(
        SUMATORIA_COMPOSICION_ACCIONARIA_FINAL BETWEEN 80 AND 100,
        CONCAT(CAST(TIPO_DOCUMENTO AS STRING), '-', CAST(KEY_ID AS STRING)),
        NULL
    )) AS RANGO_80_A_100,

    COUNT(DISTINCT IF(
        SUMATORIA_COMPOSICION_ACCIONARIA_FINAL > 100,
        CONCAT(CAST(TIPO_DOCUMENTO AS STRING), '-', CAST(KEY_ID AS STRING)),
        NULL
    )) AS MAYOR_100

FROM final_marcada

GROUP BY
    ORIGEN_RESULTADO

ORDER BY
    ORIGEN_RESULTADO;
