ultima AS (
  -- Último corte disponible en la tabla de pólizas
  SELECT 
    MAX(DATE(FECHA_PROCESO)) AS periodo_max
  FROM `sb-ecosistemaanalitico-lago.seguros_bolivar.t_polizas_riesgos_endosos`
),

polizas_actuales AS (
  -- Pólizas vigentes actualmente, tomando únicamente el último corte disponible
  SELECT
    CAST(t.CODIGO_COMPANIA AS INT64) AS CODIGO_COMPANIA,
    CAST(t.TIPO_DOCUMENTO_TOMADOR AS STRING) AS TIPO_DOCUMENTO_TOMADOR,

    REGEXP_REPLACE(
      TRIM(CAST(t.KEY_ID_TOMADOR AS STRING)),
      r'\.0$',
      ''
    ) AS KEY_ID_TOMADOR,

    REGEXP_REPLACE(
      TRIM(CAST(t.NUMERO_POLIZA AS STRING)),
      r'\.0$',
      ''
    ) AS NUMERO_POLIZA,

    ANY_VALUE(CAST(t.CODIGO_RAMO_EMISION AS STRING)) AS CODIGO_RAMO_EMISION,
    ANY_VALUE(CAST(t.NOMBRE_RAMO_EMISION AS STRING)) AS NOMBRE_RAMO_EMISION,
    ANY_VALUE(CAST(t.CODIGO_PRODUCTO AS STRING)) AS CODIGO_PRODUCTO,
    ANY_VALUE(CAST(t.NOMBRE_PRODUCTO AS STRING)) AS NOMBRE_PRODUCTO,

    SUM(SAFE_CAST(t.PRIMA_ANUAL AS NUMERIC)) AS PRIMA_ANUAL_TOTAL,

    u.periodo_max AS PERIODO_CONSULTADO

  FROM `sb-ecosistemaanalitico-lago.seguros_bolivar.t_polizas_riesgos_endosos` t
  CROSS JOIN ultima u
  CROSS JOIN parametros p

  WHERE DATE(t.FECHA_PROCESO) = u.periodo_max

    -- Filtro de NIT consultados
    AND REGEXP_REPLACE(
          TRIM(CAST(t.KEY_ID_TOMADOR AS STRING)),
          r'\.0$',
          ''
        ) IN UNNEST(p.lista_nits)

    -- Filtro para persona jurídica
    AND CAST(t.TIPO_DOCUMENTO_TOMADOR AS STRING) IN ('NT', 'NIT', 'NE')

    -- Regla de vigencia actual
    AND DATE(t.FECHA_INICIO_ENDOSO) <= u.periodo_max
    AND DATE(t.FECHA_FIN_ENDOSO) > u.periodo_max

    -- Validaciones mínimas de póliza
    AND t.NUMERO_POLIZA IS NOT NULL
    AND t.KEY_ID_TOMADOR IS NOT NULL

  GROUP BY
    CODIGO_COMPANIA,
    TIPO_DOCUMENTO_TOMADOR,
    KEY_ID_TOMADOR,
    NUMERO_POLIZA,
    u.periodo_max
),

polizas_ultimo_anio AS (
  -- Pólizas que estuvieron vigentes en algún momento dentro del último año
  SELECT
    CAST(t.CODIGO_COMPANIA AS INT64) AS CODIGO_COMPANIA,
    CAST(t.TIPO_DOCUMENTO_TOMADOR AS STRING) AS TIPO_DOCUMENTO_TOMADOR,

    REGEXP_REPLACE(
      TRIM(CAST(t.KEY_ID_TOMADOR AS STRING)),
      r'\.0$',
      ''
    ) AS KEY_ID_TOMADOR,

    REGEXP_REPLACE(
      TRIM(CAST(t.NUMERO_POLIZA AS STRING)),
      r'\.0$',
      ''
    ) AS NUMERO_POLIZA,

    ANY_VALUE(CAST(t.CODIGO_RAMO_EMISION AS STRING)) AS CODIGO_RAMO_EMISION,
    ANY_VALUE(CAST(t.NOMBRE_RAMO_EMISION AS STRING)) AS NOMBRE_RAMO_EMISION,
    ANY_VALUE(CAST(t.CODIGO_PRODUCTO AS STRING)) AS CODIGO_PRODUCTO,
    ANY_VALUE(CAST(t.NOMBRE_PRODUCTO AS STRING)) AS NOMBRE_PRODUCTO,

    SUM(SAFE_CAST(t.PRIMA_ANUAL AS NUMERIC)) AS PRIMA_ANUAL_TOTAL,

    MIN(DATE(t.FECHA_PROCESO)) AS PRIMER_PERIODO_IDENTIFICADO,
    MAX(DATE(t.FECHA_PROCESO)) AS ULTIMO_PERIODO_IDENTIFICADO

  FROM `sb-ecosistemaanalitico-lago.seguros_bolivar.t_polizas_riesgos_endosos` t
  CROSS JOIN parametros p
  CROSS JOIN ultima u

  WHERE DATE(t.FECHA_PROCESO) BETWEEN p.fecha_inicio_ultimo_anio AND u.periodo_max

    -- Filtro de NIT consultados
    AND REGEXP_REPLACE(
          TRIM(CAST(t.KEY_ID_TOMADOR AS STRING)),
          r'\.0$',
          ''
        ) IN UNNEST(p.lista_nits)

    -- Filtro para persona jurídica
    AND CAST(t.TIPO_DOCUMENTO_TOMADOR AS STRING) IN ('NT', 'NIT', 'NE')

    -- Regla: la póliza estuvo vigente en algún momento del último año
    AND DATE(t.FECHA_INICIO_ENDOSO) <= u.periodo_max
    AND DATE(t.FECHA_FIN_ENDOSO) >= p.fecha_inicio_ultimo_anio

    -- Validaciones mínimas de póliza
    AND t.NUMERO_POLIZA IS NOT NULL
    AND t.KEY_ID_TOMADOR IS NOT NULL

  GROUP BY
    CODIGO_COMPANIA,
    TIPO_DOCUMENTO_TOMADOR,
    KEY_ID_TOMADOR,
    NUMERO_POLIZA
),

resumen_actual AS (
  -- Conteo actual por compañía y NIT
  SELECT
    CODIGO_COMPANIA,
    KEY_ID_TOMADOR,

    COUNT(DISTINCT NUMERO_POLIZA) AS CANTIDAD_POLIZAS_VIGENTES_ACTUALMENTE,

    COUNT(
      DISTINCT CONCAT(
        IFNULL(CODIGO_PRODUCTO, 'SIN_CODIGO'),
        '-',
        IFNULL(NOMBRE_PRODUCTO, 'SIN_NOMBRE')
      )
    ) AS CANTIDAD_PRODUCTOS_VIGENTES_ACTUALMENTE,

    STRING_AGG(
      DISTINCT CONCAT(
        IFNULL(CODIGO_PRODUCTO, 'SIN_CODIGO'),
        ' - ',
        IFNULL(NOMBRE_PRODUCTO, 'SIN_NOMBRE')
      ),
      ' | '
      ORDER BY CONCAT(
        IFNULL(CODIGO_PRODUCTO, 'SIN_CODIGO'),
        ' - ',
        IFNULL(NOMBRE_PRODUCTO, 'SIN_NOMBRE')
      )
    ) AS PRODUCTOS_VIGENTES_ACTUALMENTE

  FROM polizas_actuales

  GROUP BY
    CODIGO_COMPANIA,
    KEY_ID_TOMADOR
),

resumen_ultimo_anio AS (
  -- Conteo del último año por compañía y NIT
  SELECT
    CODIGO_COMPANIA,
    KEY_ID_TOMADOR,

    COUNT(DISTINCT NUMERO_POLIZA) AS CANTIDAD_POLIZAS_VIGENTES_ULTIMO_ANIO,

    COUNT(
      DISTINCT CONCAT(
        IFNULL(CODIGO_PRODUCTO, 'SIN_CODIGO'),
        '-',
        IFNULL(NOMBRE_PRODUCTO, 'SIN_NOMBRE')
      )
    ) AS CANTIDAD_PRODUCTOS_VIGENTES_ULTIMO_ANIO,

    STRING_AGG(
      DISTINCT CONCAT(
        IFNULL(CODIGO_PRODUCTO, 'SIN_CODIGO'),
        ' - ',
        IFNULL(NOMBRE_PRODUCTO, 'SIN_NOMBRE')
      ),
      ' | '
      ORDER BY CONCAT(
        IFNULL(CODIGO_PRODUCTO, 'SIN_CODIGO'),
        ' - ',
        IFNULL(NOMBRE_PRODUCTO, 'SIN_NOMBRE')
      )
    ) AS PRODUCTOS_VIGENTES_ULTIMO_ANIO

  FROM polizas_ultimo_anio

  GROUP BY
    CODIGO_COMPANIA,
    KEY_ID_TOMADOR
),

companias_base AS (
  -- Base de compañías a evaluar
  SELECT DISTINCT
    CAST(CODIGO_COMPANIA AS INT64) AS CODIGO_COMPANIA
  FROM `sb-ecosistemaanalitico-lago.seguros_bolivar.t_polizas_riesgos_endosos`
  WHERE CODIGO_COMPANIA IS NOT NULL
),

base_final AS (
  -- Cruce de todos los NIT consultados contra cada compañía
  SELECT
    c.CODIGO_COMPANIA,
    nit AS KEY_ID_TOMADOR
  FROM companias_base c
  CROSS JOIN parametros p
  CROSS JOIN UNNEST(p.lista_nits) AS nit
)

SELECT
  b.CODIGO_COMPANIA,

  CASE 
    WHEN b.CODIGO_COMPANIA = 1 THEN 'CAPITALIZADORA BOLIVAR'
    WHEN b.CODIGO_COMPANIA = 2 THEN 'SEGUROS BOLIVAR'
    WHEN b.CODIGO_COMPANIA = 3 THEN 'SEGUROS COMERCIALES BOLIVAR'
    ELSE 'OTRA COMPANIA'
  END AS NOMBRE_COMPANIA,

  'NT' AS TIPO_DOCUMENTO_TOMADOR,

  b.KEY_ID_TOMADOR,

  -- Vigencia actual
  CASE 
    WHEN IFNULL(ra.CANTIDAD_POLIZAS_VIGENTES_ACTUALMENTE, 0) > 0 THEN 'SI'
    ELSE 'NO'
  END AS TIENE_PRODUCTO_VIGENTE_ACTUALMENTE,

  IFNULL(
    ra.CANTIDAD_POLIZAS_VIGENTES_ACTUALMENTE,
    0
  ) AS CANTIDAD_POLIZAS_VIGENTES_ACTUALMENTE,

  IFNULL(
    ra.CANTIDAD_PRODUCTOS_VIGENTES_ACTUALMENTE,
    0
  ) AS CANTIDAD_PRODUCTOS_VIGENTES_ACTUALMENTE,

  IFNULL(
    ra.PRODUCTOS_VIGENTES_ACTUALMENTE,
    'SIN PRODUCTOS VIGENTES ACTUALES'
  ) AS PRODUCTOS_VIGENTES_ACTUALMENTE,

  -- Vigencia último año
  CASE 
    WHEN IFNULL(rua.CANTIDAD_POLIZAS_VIGENTES_ULTIMO_ANIO, 0) > 0 THEN 'SI'
    ELSE 'NO'
  END AS TUVO_PRODUCTO_VIGENTE_ULTIMO_ANIO,

  IFNULL(
    rua.CANTIDAD_POLIZAS_VIGENTES_ULTIMO_ANIO,
    0
  ) AS CANTIDAD_POLIZAS_VIGENTES_ULTIMO_ANIO,

  IFNULL(
    rua.CANTIDAD_PRODUCTOS_VIGENTES_ULTIMO_ANIO,
    0
  ) AS CANTIDAD_PRODUCTOS_VIGENTES_ULTIMO_ANIO,

  IFNULL(
    rua.PRODUCTOS_VIGENTES_ULTIMO_ANIO,
    'SIN PRODUCTOS VIGENTES EN EL ULTIMO ANIO'
  ) AS PRODUCTOS_VIGENTES_ULTIMO_ANIO,

  -- Fecha de referencia del análisis
  u.periodo_max AS PERIODO_CORTE_ACTUAL,

  DATE_SUB(
    u.periodo_max,
    INTERVAL 1 YEAR
  ) AS FECHA_INICIO_ANALISIS_ULTIMO_ANIO

FROM base_final b

CROSS JOIN ultima u

LEFT JOIN resumen_actual ra
  ON b.CODIGO_COMPANIA = ra.CODIGO_COMPANIA
  AND b.KEY_ID_TOMADOR = ra.KEY_ID_TOMADOR

LEFT JOIN resumen_ultimo_anio rua
  ON b.CODIGO_COMPANIA = rua.CODIGO_COMPANIA
  AND b.KEY_ID_TOMADOR = rua.KEY_ID_TOMADOR

ORDER BY
  b.KEY_ID_TOMADOR,
  b.CODIGO_COMPANIA;
