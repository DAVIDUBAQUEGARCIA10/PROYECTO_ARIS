base_proveedores AS (

  SELECT DISTINCT
    'COUPA' AS fuente,
    CAST(FECHA_REQUERIDA_ENTREGA_ITEM AS TIMESTAMP) AS fecha_transaccion,
    TIPO_DOCUMENTO_PROVEEDOR AS tip_doc_proveedor,
    CAST(KEY_ID_PROVEEDOR AS STRING) AS key_id_proveedor,
    NUMERO_ORDEN_COMPRA AS nro_factura,
    CAST(NOMBRE_UNIDAD_DE_NEGOCIO AS STRING) AS compania,
    CAST(VALOR_TOTAL_ORDEN_INCLUYENDO_IMPUESTOS_ESTIMADOS AS NUMERIC) AS vlr_total_factura,
    CAST(NULL AS STRING) AS fecha_estado_proceso
  FROM `sb-ecosistemaanalitico-lago.financiero_seguros_bolivar.t_transacciones_proveedores`

  UNION ALL

  SELECT DISTINCT
    'FACTURA_ELECTRONICA',
    CAST(fec_emision_factura AS TIMESTAMP),
    tip_doc_proveedor,
    CAST(key_id_proveedor AS STRING),
    nro_factura,
    CAST(nit_compania AS STRING),
    CAST(vlr_total_factura AS NUMERIC),
    CAST(fecha_estado_proceso AS STRING)
  FROM `sb-ecosistemaanalitico-lago.seguros_bolivar.evento_factura_electronica`

  UNION ALL

  SELECT DISTINCT
    'ORDEN_PAGO',
    CAST(FECHA_PAGO_REAL AS TIMESTAMP),
    CAST(TIPO_DOCUMENTO_BENEFICIARIO AS STRING),
    CAST(NUMERO_DOCUMENTO_BENEFICIARIO AS STRING),
    CAST(NUMERO_ORDEN_PAGO AS STRING),
    CAST(COMPANIA_ORIGEN AS STRING),
    CAST(VALOR_TOTAL_PAGO AS NUMERIC),
    CAST(NULL AS STRING)
  FROM `sb-ecosistemaanalitico-lago.financiero_seguros_bolivar.t_ordenes_pago_con_restriccion`

  UNION ALL

  SELECT DISTINCT
    'CUENTA_COBRO',
    CAST(fecha_emision AS TIMESTAMP),
    codigo_tipo_identificacion_emisor,
    CAST(key_id_emisor AS STRING),
    numero_documento,
    CAST(razon_social_cia AS STRING),
    CAST((valor_base + IFNULL(valor_iva,0)) AS NUMERIC),
    CAST(NULL AS STRING)
  FROM `sb-ecosistemaanalitico-lago.seguros_bolivar.cuentas_de_cobro_proveedores`
),

base_homologada AS (
  SELECT
    bp.compania AS nit_compania,
    COALESCE(hc.COMPANIA_HOMOLOGADA, bp.compania) AS compania_homologada,
    bp.fuente,
    bp.nro_factura,
    DATE(bp.fecha_transaccion) AS fecha_emision,
    FORMAT_DATE('%Y-%m', DATE(bp.fecha_transaccion)) AS periodo_mes,
    bp.tip_doc_proveedor,
    bp.key_id_proveedor,
    bp.vlr_total_factura,
    bp.fecha_estado_proceso
  FROM base_proveedores bp
  LEFT JOIN homologacion_compania hc
    ON TRIM(bp.compania) = TRIM(hc.COMPANIA_ORIGINAL)
  WHERE bp.key_id_proveedor IS NOT NULL
    AND DATE(bp.fecha_transaccion) >= DATE '2025-01-01'
),

base_alerta AS (
  SELECT
    b.*,
    r.CODIGO_RESTRICCION,
    r.DESCRIPCION,
    FORMAT_DATE('%Y-%m', CURRENT_DATE()) AS FECHA_ALERTA_MES,
    CURRENT_DATE() AS FECHA_ALERTA
  FROM base_homologada b
  LEFT JOIN `sb-ecosistemaanalitico-lago.seguros_bolivar.t_terceros_restringidos` r
    ON b.tip_doc_proveedor = r.TIPO_DOCUMENTO_TERCERO
   AND b.key_id_proveedor = r.KEY_ID
),

numeradas AS (
  SELECT *,
    ROW_NUMBER() OVER (
      PARTITION BY tip_doc_proveedor, key_id_proveedor, periodo_mes,vlr_total_factura,fecha_emision
      ORDER BY fecha_emision DESC, vlr_total_factura DESC,
        CASE
          WHEN fuente = 'COUPA' THEN 1
          WHEN fuente = 'FACTURA_ELECTRONICA' THEN 2
          WHEN fuente = 'ORDEN_PAGO' THEN 3
          WHEN fuente = 'CUENTA_COBRO' THEN 4
          ELSE 99
        END
    ) AS rn
  FROM base_alerta
)

SELECT
  nit_compania,
  compania_homologada,
  fuente,
  nro_factura,
  fecha_emision,
  tip_doc_proveedor,
  key_id_proveedor,
  vlr_total_factura,
  fecha_estado_proceso,
  CODIGO_RESTRICCION,
  DESCRIPCION,
  FECHA_ALERTA_MES,
  FECHA_ALERTA
FROM numeradas n
