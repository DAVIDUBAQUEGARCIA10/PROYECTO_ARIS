SELECT DISTINCT
    CODIGO_COMPANIA,
    CODIGO_RAMO_EMISION,
    NOMBRE_RAMO_EMISION,
    CODIGO_PRODUCTO,
    NOMBRE_PRODUCTO,
    CODIGO_SUBPRODUCTO,
    NOMBRE_SUBPRODUCTO,
    NUMERO_POLIZA_ANTERIOR,
    NUMERO_POLIZA,
    TIPO_DOCUMENTO_TOMADOR,
    KEY_ID_TOMADOR,
    FECHA_INICIO_POLIZA,
    FECHA_FIN_ENDOSO,
    FECHA_FIN_POLIZA,
    CAST(VALOR_ASEGURADO AS INT64) AS VALOR_ASEGURADO,   -- 👈 aquí
    CAST(PRIMA_EMITIDA AS INT64) AS PRIMA_EMITIDA,       -- 👈 y aquí
    CODIGO_COBERTURA,
    NOMBRE_COBERTURA,
    PERIODO_FACTURACION
FROM `sb-ecosistemaanalitico-lago.seguros_bolivar.t_polizas_riesgos_endosos`
WHERE DATE(FECHA_FIN_ENDOSO) > DATE '2026-03-01'
  AND CODIGO_RAMO_EMISION IN (50)
  AND CODIGO_PRODUCTO IN (620, 622, 624, 628, 630, 636)
  AND NUMERO_POLIZA_ANTERIOR IS NOT NULL
  AND CODIGO_COMPANIA = 2
  AND NUMERO_ENDOSO = 0
  AND CODIGO_RIESGO = 1
  AND MARCA_ANULACION != 'S'
  AND DATE(FECHA_INICIO_ENDOSO) > DATE '2026-03-01'
  AND DATE(FECHA_EMISION_ENDOSO) > DATE '2026-03-01'
