SELECT 
    A.EMPLOYEETYPE AS TIPO_DOCUMENTO,
    A.CN AS CEDULA,
    A.NRFASSIGNEDROLES AS ROLES_ASIGNADOS,
    A.NRFINHERITEDROLES AS ROLES_HEREDADOS,
    A.DIRXML_DRIVERCACHELIMIT AS LIMITE_CACHE_CONTROLADOR,
    A.DIRXML_LOGEVENTS AS EVENTOS_LOG_DIRECTORIO,
    A.COMPANY AS EMPRESA,
    A.USRTIPO AS TIPO_USUARIO,
    A.EMPLOYEESTATUS AS ESTADO_EMPLEADO,
    A.USRLOCATIONDESCRIPTION AS DESCRIPCION_UBICACION_USUARIO,
    A.LOGINGRACELIMIT AS LIMITE_INTENTOS_LOGIN,
    A.CITY AS CIUDAD,
    A.DIRXML_TIMESTAMP AS FECHA_HORA_DIRECTORIO,
    A.WORKFORCEID AS IDENTIFICADOR_FUERZA_LABORAL,
    A.USRSUBTIPO AS SUBTIPO_USUARIO,
    A.L AS LOCALIDAD,
    A.LOGINTIME AS FECHA_HORA_LOGIN,
    A.DIRXML_PKGCHECKSUM AS CHECKSUM_PAQUETE_DIRECTORIO,
    A.JOBCODEDESCRIPTION AS DESCRIPCION_CARGO,
    A.FULLNAME AS NOMBRE_COMPLETO,
    A.HOMEEMAILADDRESS AS CORREO_ELECTRONICO_PERSONAL,
    A.MANAGER AS MANAGER,
    A.SBCODACTBENEF AS CODIGO_ACTIVIDAD_BENEFICIO,
    A.SBDESCLOC AS DESCRIPCION_UBICACION,
    A.DIRXML_TIMESTAMP2 AS SEGUNDA_FECHA_DIRECTORIO,
    A.GROUPMEMBERSHIP AS MEMBRESIA_GRUPOS,
    A.JOBCODE AS CODIGO_CARGO,
    A.DIRXML_DRIVERID AS IDENTIFICADOR_CONTROLADOR,
    A.DIRXML_PKGASSOCIATIONID AS IDENTIFICADOR_ASOCIACION_PAQUETE,
    A.PASSWORDEXPIRATIONTIME AS FECHA_EXPIRACION_CONTRASENA,
    A.SBMANAGERCEDULA AS CODIGO_MANEJO,
    A.DIRXML_STATE AS ESTADO_DIRECTORIO,
    A.DIRXML_DRIVERSTARTOPTION AS OPCION_INICIO_CONTROLADOR,
    A.DIRXML_PKGGUID AS IDENTIFICADOR_UNICO_PAQUETE,
    A.DIRXML_PASSWORDSYNCSTATUS AS ESTADO_SINCRONIZACION_CONTRASENA,
    A.CREATETIMESTAMP AS FECHA_CREACION,
    A.SBTIPOIDENTIFJEFE AS TIPO_IDENTIFICACION_JEFE,
    A.USRLOCATIONCODE AS CODIGO_UBICACION_USUARIO,
    A.DIRXML_ASSOCIATIONS AS ASOCIACIONES_DIRECTORIO,
    A.MAIL AS CORREO_ELECTRONICO,
    A.DIRXML_DRIVERVERSION AS VERSION_CONTROLADOR,
    A.SBROLESORG AS ROLES_ORGANIZACIONALES,
    A.LOGINDISABLED AS LOGIN_DESHABILITADO,
    A.LASTLOGINTIME2 AS ULTIMA_FECHA_LOGIN,
    A.CUSTTIPOIDENTIDAD AS TIPO_IDENTIDAD_CLIENTE,
    A.USRCTATRONADOR AS CUENTA_TRONADOR_USUARIO,
    A.DIRXML_ENTITLEMENTREF AS REFERENCIA_DERECHOS,
    CONCAT(A.DIRXML_PASSWORDSYNCSTATUS, '/', A.CN) AS ROLES_HEREDADOS_CEDULA_2,
    B.FUENTE AS FUENTE,
    B.EMPRESA_RELACION AS EMPRESA_RELACION,
    B.EMPRESA_CONTRATANTE_NOMBRE AS EMPRESA_CONTRATANTE_NOMBRE,
    B.CLASE_VINCULACION AS CLASE_VINCULACION,
    B.DESCRIPCION_TIPO_RELACION AS DESCRIPCION_TIPO_RELACION,
    B.NOMBRE_DEPARTAMENTO_EMPRESA AS NOMBRE_DEPARTAMENTO_EMPRESA

FROM `sb-ecosistemaanalitico-lago.pruebas_usuarios.temp_idm_identidades_idm` AS A

LEFT JOIN (
    SELECT DISTINCT
        TIPO_DOCUMENTO,
        KEY_ID,
        FUENTE,
        EMPRESA_RELACION,
        EMPRESA_CONTRATANTE_NOMBRE,
        CLASE_VINCULACION,
        DESCRIPCION_TIPO_RELACION,
        NOMBRE_DEPARTAMENTO_EMPRESA
    FROM `sb-ecosistemaanalitico-lago.people_analytics_prod.v_colaboradores_activos`
    WHERE FECHA_CIERRE = (
        SELECT MAX(FECHA_CIERRE)
        FROM `sb-ecosistemaanalitico-lago.people_analytics_prod.v_colaboradores_activos`
    )
) AS B
    ON A.CN = B.KEY_ID
   AND A.EMPLOYEETYPE = B.TIPO_DOCUMENTO;
