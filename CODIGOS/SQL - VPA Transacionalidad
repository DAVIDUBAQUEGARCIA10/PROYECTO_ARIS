SELECT
    NIT_NEGOCIO, NIT_FONDO, CUENTA_FONDO, CLASE_SALDO, SECUENCIA, TRANSACCION, SUB_TRANSACCION, FECHA_PROCESO, VLR_TRANSACCION, UNIDADES_TOTALES, UNIDADES_CONTINGENTE, VLR_CONTINGENTE, ESTADO_PORTAFOLIO, FECHA_INVERSION, VALOR_PERDIDA, VALOR_RENDIMIENTO, VALOR_RETENCION, VALOR_MULTA, DIAS_MOVIMIENTO, FECHA_APLICACION, CUENTA_FONDO_REFERENCIA, CLASE_SALDO_REFERENCIA, SECUENCIA_REFERENCIA, TRANSACCION_REFERENCIA, MULTA_SUB_TRANSACCION, ESTADO_DETALLE, CLASE_APORTE, FECHA_ULT_MODIFICACION, USUARIO, SALDO_ANTERIOR_MULTIFONDO, FACTOR_COMISION, CONCEPTO_RETENCION, PORCENTAJE_APLICADO, FECHA_CONTINGENCIA, NUMERO_OPERACION, DESCRIPCION, VLR_CONTINGENTE_X_PAGAR,

    CASE TO_NUMBER(d.SUB_TRANSACCION)
        WHEN 1  THEN 'APORTE AFILIADO (CAJAS BOLIVAR)'
        WHEN 2  THEN 'RETIRO RIESGO'
        WHEN 3  THEN 'APORTE EXTRAORDINARIO'
        WHEN 4  THEN 'APORTE CONVENIO'
        WHEN 5  THEN 'APORTE TRASLADO FPU'
        WHEN 6  THEN 'APORTE CONVERSION'
        WHEN 7  THEN 'TRASL.DISPONIBLE RIESGO A FPU'
        WHEN 8  THEN 'TRASL.DISPON.RIESGO'
        WHEN 9  THEN 'AJUSTE RENDIMIENTOS'
        WHEN 10 THEN 'DEVOLUCION RECAUDO'
        WHEN 11 THEN 'DEVOLUCION RIESGO NO APLICADO'
        WHEN 12 THEN 'REVERSION RETIRO'
        ELSE 'SIN HOMOLOGACION'
    END AS NOMBRE_SUB_TRANSACCION

FROM detalle_cuenta_multifondo d
WHERE d.FECHA_ULT_MODIFICACION >= TO_DATE('20/02/2021','DD/MM/YYYY')
  AND d.CUENTA_FONDO = 20611312510 and SUB_TRANSACCION = 3
ORDER BY d.FECHA_ULT_MODIFICACION DESC;
