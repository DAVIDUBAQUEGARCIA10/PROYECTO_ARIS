WITH alertas_filtradas AS (
    SELECT
        NUMERO_POLIZA,
        KEY_ID_TOMADOR,
        TIPO_DOCUMENTO_TOMADOR,
        ANO_MES,
        Justificacion_Anomalia,
        anomaly_score,
        CAST(FLOOR(SAFE_CAST(NUMERO_POLIZA AS INT64) / 100) AS INT64) AS NUMERO_CUENTA_FONDO_ALERTA
    FROM `sb-sandbox-usuarios.sandbox_cumplimiento.alertas_clave_seg_pn`
    WHERE  ANO_MES = (
        SELECT MAX(ANO_MES)
        FROM `sb-sandbox-usuarios.sandbox_cumplimiento.alertas_clave_seg_pn`
    )
      AND causa_principal != 'Comportamiento normal'
),

aportes_extraordinarios AS (
    SELECT
        TIPO_DOCUMENTO_TOMADOR,
        KEY_ID_TOMADOR,
        NUMERO_CUENTA_FONDO,
        CLASE_SALDO,
        CONSECUTIVO_OPERACION,
        TRANSACCION,
        SUB_TRANSACCION,
        FECHA_PROCESO,
        VALOR_TRANSACCION,
        UNIDADES_TOTALES,
        UNIDADES_CONTINGENTE,
        VALOR_CONTINGENTE,
        ESTADO_PORTAFOLIO,
        FECHA_INVERSION,
        VALOR_PERDIDA,
        VALOR_RENDIMIENTO,
        VALOR_RETENCION,
        VALOR_MULTA,
        DIAS_MOVIMIENTO,
        FECHA_APLICACION,
        CUENTA_FONDO_REFERENCIA,
        CLASE_SALDO_REFERENCIA,
        SECUENCIA_REFERENCIA,
        TRANSACCION_REFERENCIA,
        MULTA_SUB_TRANSACCION,
        ESTADO_DETALLE,
        CLASE_APORTE,
        FECHA_ULTIMA_MODIFICACION,
        SALDO_ANTERIOR_MULTIFONDO,
        FACTOR_COMISION,
        CONCEPTO_RETENCION,
        PORCENTAJE_APLICADO,
        FECHA_CONTINGENCIA,
        NUMERO_OPERACION,
        DETALLE_OPERACION_EMMASCARADO,
        VALOR_CONTINGENTE_POR_PAGAR,
        CODIGO_COMPANIA,
        CODIGO_RAMO_EMISION,
        NOMBRE_RAMO_EMISION,
        CODIGO_PRODUCTO,
        NOMBRE_PRODUCTO,
        NOMBRE_SUB_TRANSACCION
    FROM `sb-ecosistemaanalitico-lago.seguros_bolivar.t_aportes_extraordinarios`
WHERE FECHA_PROCESO >= "2026-03-01"
),

polizas_objetivo AS (
    SELECT DISTINCT NUMERO_POLIZA
    FROM alertas_filtradas
),

polizas_recientes AS (
    SELECT
        p.CODIGO_COMPANIA,
        p.CODIGO_RAMO_EMISION,
        p.NOMBRE_RAMO_EMISION,
        p.CODIGO_PRODUCTO,
        p.NOMBRE_PRODUCTO,
        p.NUMERO_POLIZA,
        p.MARCA_ANULACION,
        p.FECHA_PROCESO
    FROM `sb-ecosistemaanalitico-lago.seguros_bolivar.t_polizas_riesgos_endosos` p
    INNER JOIN polizas_objetivo o
        ON SAFE_CAST(p.NUMERO_POLIZA AS STRING) = SAFE_CAST(o.NUMERO_POLIZA AS STRING)
    QUALIFY ROW_NUMBER() OVER (
        PARTITION BY p.NUMERO_POLIZA
        ORDER BY p.FECHA_PROCESO DESC
    ) = 1
)

SELECT
    a.NUMERO_POLIZA,
    a.NUMERO_CUENTA_FONDO_ALERTA,
    a.KEY_ID_TOMADOR,
    a.TIPO_DOCUMENTO_TOMADOR,
    a.ANO_MES,
    a.Justificacion_Anomalia,
    a.anomaly_score,

    t.NUMERO_CUENTA_FONDO,
    t.CLASE_SALDO,
    t.CONSECUTIVO_OPERACION,
    t.TRANSACCION,
    t.SUB_TRANSACCION,
    t.FECHA_PROCESO AS FECHA_PROCESO_TRANSACCION,
    t.VALOR_TRANSACCION,
    t.UNIDADES_TOTALES,
    t.UNIDADES_CONTINGENTE,
    t.VALOR_CONTINGENTE,
    t.ESTADO_PORTAFOLIO,
    t.FECHA_INVERSION,
    t.VALOR_PERDIDA,
    t.VALOR_RENDIMIENTO,
    t.VALOR_RETENCION,
    t.VALOR_MULTA,
    t.DIAS_MOVIMIENTO,
    t.FECHA_APLICACION,
    t.CUENTA_FONDO_REFERENCIA,
    t.CLASE_SALDO_REFERENCIA,
    t.SECUENCIA_REFERENCIA,
    t.TRANSACCION_REFERENCIA,
    t.MULTA_SUB_TRANSACCION,
    t.ESTADO_DETALLE,
    t.CLASE_APORTE,
    t.FECHA_ULTIMA_MODIFICACION,
    t.SALDO_ANTERIOR_MULTIFONDO,
    t.FACTOR_COMISION,
    t.CONCEPTO_RETENCION,
    t.PORCENTAJE_APLICADO,
    t.FECHA_CONTINGENCIA,
    t.NUMERO_OPERACION,
    t.DETALLE_OPERACION_EMMASCARADO,
    t.VALOR_CONTINGENTE_POR_PAGAR,
    t.CODIGO_COMPANIA AS CODIGO_COMPANIA_TRANSACCION,
    t.CODIGO_RAMO_EMISION AS CODIGO_RAMO_EMISION_TRANSACCION,
    t.NOMBRE_RAMO_EMISION AS NOMBRE_RAMO_EMISION_TRANSACCION,
    t.CODIGO_PRODUCTO AS CODIGO_PRODUCTO_TRANSACCION,
    t.NOMBRE_PRODUCTO AS NOMBRE_PRODUCTO_TRANSACCION,
    t.NOMBRE_SUB_TRANSACCION,

    p.CODIGO_COMPANIA AS CODIGO_COMPANIA_POLIZA,
    p.CODIGO_RAMO_EMISION AS CODIGO_RAMO_EMISION_POLIZA,
    p.NOMBRE_RAMO_EMISION AS NOMBRE_RAMO_EMISION_POLIZA,
    p.CODIGO_PRODUCTO AS CODIGO_PRODUCTO_POLIZA,
    p.NOMBRE_PRODUCTO AS NOMBRE_PRODUCTO_POLIZA,
    p.MARCA_ANULACION,
    p.FECHA_PROCESO AS FECHA_PROCESO_POLIZA

FROM alertas_filtradas a

INNER JOIN aportes_extraordinarios t
    ON a.NUMERO_CUENTA_FONDO_ALERTA = SAFE_CAST(t.NUMERO_CUENTA_FONDO AS INT64)

INNER JOIN polizas_recientes p
    ON SAFE_CAST(a.NUMERO_POLIZA AS STRING) = SAFE_CAST(p.NUMERO_POLIZA AS STRING)
WHERE MARCA_ANULACION != "S"
AND VALOR_TRANSACCION  >= 7056841 
ORDER BY
    a.NUMERO_POLIZA,
    t.FECHA_PROCESO DESC;
