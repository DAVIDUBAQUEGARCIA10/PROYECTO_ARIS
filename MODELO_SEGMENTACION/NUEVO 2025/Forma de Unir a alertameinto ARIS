

SELECT DISTINCT
    "CC" AS TIPO_DOCUMENTO_TOMADOR,
    CAST(c.KEY_ID_TOMADOR AS STRING) AS KEY_ID_TOMADOR,
    0 AS NUMERO_POLIZA,
    'Factor_Cliente' AS ALERTA,
    'Cambio del factor de riesgo en el modelo de segmentación de un cluster de bajo riesgo a un cluster de alto riesgo, mensualmente.' AS DESCRIPCION_ALERTA,     
    2 AS COMPANIA,
    FORMAT_DATE('%Y-%m', FECHA_CORTE_MES) AS FECHA_ALERTA_MES,
    FECHA_CORTE_MES AS FECHA_ALERTA,
    CAST(FECHA_CORTE_MES AS DATE) AS FECHA_TRANSACCION,
    CAST(0 AS STRING) AS VALOR_TRANSACCION,     
    CONCAT(
    'El cliente presenta un nivel de riesgo ', COALESCE(NIVEL_DE_RIESGO, '0'),
    ', con una razón Activos/Pasivos de ', COALESCE(CAST(ACTIVO_PASIVO AS STRING), '0'),
    ', código CIIU ', COALESCE(CAST(CODIGO_CIIU_NUM AS STRING), '0'),
    ' y un nivel de riesgo por profesión de ', COALESCE(CAST(NIVEL_RIESGO_PROFESION_NUM AS STRING), '0'),
    '. Presenta una alta variabilidad en su transaccionalidad (siniestros o recaudo),',
    ' en los últimos 12 meses teniendo en cuenta todos sus productos activos para cada compañía,',
    ' lo que lo ubica en un cluster de mayor riesgo: ', COALESCE(CAST(cluster_labels AS STRING), '0')
    ) AS FORMA_PAGO_CANAL,
    0 AS CODIGO_RAMO,
    0 AS CODIGO_PRODUCTO,
     'Segmentacion ' AS SUBCATEGORIA,
     'Operacion Alertada' AS ESTADO_IDENTIFICACION                
FROM
    `sb-sandbox-usuarios.sandbox_cumplimiento.seguros_bolivar_pn_cliente_segmentacion_modelo_transaccional_6` AS c



