registros_superan_umbral AS (
  SELECT
    bf.FUENTE,
    bf.FECHA_TRANSACCION,
    bf.TIPO_DOCUMENTO_PROVEEDOR,
    bf.NOMBRE_PROVEEDOR,
    bf.KEY_ID_PROVEEDOR,
    bf.MONEDA,
    bf.ORDEN_FACTURA,
    bf.COMPANIA,
    bf.COMPANIA_HOMOLOGADA,
    bf.TIPO_PERSONA,
    bf.VALOR_SIN_IMPUESTOS,
    bf.VALOR_CON_IMPUESTOS,
    p.PERCENTIL_98 AS UMBRAL_PERCENTIL,
    bf.AREA_SOLICITANTE,
    bf.CIUDAD_PROVEEDOR,
    bf.DETALLE
  FROM base_final bf
  INNER JOIN percentiles_parametrizados p
    ON bf.COMPANIA_HOMOLOGADA = p.COMPANIA_HOMOLOGADA
   AND bf.FUENTE = p.FUENTE
   AND bf.TIPO_PERSONA = p.TIPO_PERSONA
  WHERE bf.VALOR_CON_IMPUESTOS > p.PERCENTIL_98
)

SELECT
  r.FUENTE,
  r.FECHA_TRANSACCION,
  r.TIPO_DOCUMENTO_PROVEEDOR,
  r.NOMBRE_PROVEEDOR,
  r.KEY_ID_PROVEEDOR,
  r.MONEDA,
  r.ORDEN_FACTURA,
  r.COMPANIA,
  r.COMPANIA_HOMOLOGADA,
  r.TIPO_PERSONA,
  r.VALOR_SIN_IMPUESTOS,
  r.VALOR_CON_IMPUESTOS,
  r.UMBRAL_PERCENTIL,
  r.AREA_SOLICITANTE,
  r.CIUDAD_PROVEEDOR,
  r.DETALLE
FROM registros_superan_umbral r
WHERE DATE(r.FECHA_TRANSACCION) >= DATE '2026-03-01'
  AND NOT EXISTS (
    SELECT 1
    FROM `sb-ecosistemaanalitico-lago.cumplimiento_normativo_prod.PROV_0004` t
    WHERE t.FUENTE = r.FUENTE
      AND TIMESTAMP(t.FECHA_TRANSACCION) = r.FECHA_TRANSACCION
      AND IFNULL(TRIM(t.KEY_ID_PROVEEDOR), '') = IFNULL(TRIM(r.KEY_ID_PROVEEDOR), '')
      AND IFNULL(TRIM(t.ORDEN_FACTURA), '') = IFNULL(TRIM(r.ORDEN_FACTURA), '')
      AND IFNULL(TRIM(t.COMPANIA_HOMOLOGADA), '') = IFNULL(TRIM(r.COMPANIA_HOMOLOGADA), '')
  );











ORDER BY FECHA_TRANSACCION DESC;
