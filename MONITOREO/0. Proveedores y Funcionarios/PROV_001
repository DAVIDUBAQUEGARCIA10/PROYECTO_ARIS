base_proveedores AS (

  SELECT DISTINCT
    'COUPA' AS FUENTE,
    CAST(FECHA_REQUERIDA_ENTREGA_ITEM AS TIMESTAMP) AS FECHA_TRANSACCION,
    TIPO_DOCUMENTO_PROVEEDOR,
    NOMBRE_PROVEEDOR_ENCRIPTADO AS NOMBRE_PROVEEDOR,
    CAST(KEY_ID_PROVEEDOR AS STRING) AS KEY_ID_PROVEEDOR,
    COD_MONEDA_TRANSACCION AS MONEDA,
    NUMERO_ORDEN_COMPRA AS ORDEN_FACTURA,
    CAST(NOMBRE_UNIDAD_DE_NEGOCIO AS STRING) AS COMPANIA,
    CAST(VALOR_TOTAL_ORDEN_INCLUYENDO_IMPUESTOS_ESTIMADOS AS NUMERIC) AS VALOR_TRANSACCION,
    CAST(NULL AS STRING) AS FECHA_ESTADO_PROCESO
  FROM `sb-ecosistemaanalitico-lago.financiero_seguros_bolivar.t_transacciones_proveedores` t
  WHERE CAST(NUMERO_LINEA_ITEM_COMPRA AS INT64) = (
    SELECT MAX(CAST(NUMERO_LINEA_ITEM_COMPRA AS INT64))
    FROM `sb-ecosistemaanalitico-lago.financiero_seguros_bolivar.t_transacciones_proveedores`
    WHERE NUMERO_ORDEN_COMPRA = t.NUMERO_ORDEN_COMPRA
  )

  UNION ALL

  SELECT DISTINCT
    'FACTURA_ELECTRONICA' AS FUENTE,
    CAST(fec_emision_factura AS TIMESTAMP) AS FECHA_TRANSACCION,
    tip_doc_proveedor AS TIPO_DOCUMENTO_PROVEEDOR,
    razon_social_proveedor AS NOMBRE_PROVEEDOR,
    CAST(key_id_proveedor AS STRING) AS KEY_ID_PROVEEDOR,
    CAST(cod_moneda AS STRING) AS MONEDA,
    nro_factura AS ORDEN_FACTURA,
    CAST(nit_compania AS STRING) AS COMPANIA,
    CAST(vlr_total_factura AS NUMERIC) AS VALOR_TRANSACCION,
    CAST(fecha_estado_proceso AS STRING) AS FECHA_ESTADO_PROCESO
  FROM `sb-ecosistemaanalitico-lago.seguros_bolivar.evento_factura_electronica`

  UNION ALL

  SELECT DISTINCT
    'ORDEN_PAGO' AS FUENTE,
    CAST(FECHA_PAGO_REAL AS TIMESTAMP) AS FECHA_TRANSACCION,
    CAST(TIPO_DOCUMENTO_BENEFICIARIO AS STRING) AS TIPO_DOCUMENTO_PROVEEDOR,
    CAST(NULL AS STRING) AS NOMBRE_PROVEEDOR,
    CAST(NUMERO_DOCUMENTO_BENEFICIARIO AS STRING) AS KEY_ID_PROVEEDOR,
    CAST(NULL AS STRING) AS MONEDA,
    CAST(NUMERO_ORDEN_PAGO AS STRING) AS ORDEN_FACTURA,
    CAST(COMPANIA_ORIGEN AS STRING) AS COMPANIA,
    CAST(VALOR_TOTAL_PAGO AS NUMERIC) AS VALOR_TRANSACCION,
    CAST(NULL AS STRING) AS FECHA_ESTADO_PROCESO
  FROM (
    SELECT *
    FROM (
      SELECT
        t.*,
        ROW_NUMBER() OVER (
          PARTITION BY NUMERO_ORDEN_PAGO, NUMERO_DOCUMENTO_BENEFICIARIO
          ORDER BY
            CASE
              WHEN DESCRIPCION_CONCEPTO_CONTABLE IS NOT NULL
                   AND TRIM(DESCRIPCION_CONCEPTO_CONTABLE) <> '' THEN 1
              ELSE 2
            END,
            FECHA_PAGO_REAL DESC
        ) AS RN
      FROM `sb-ecosistemaanalitico-lago.financiero_seguros_bolivar.t_ordenes_pago_con_restriccion` t
      WHERE FECHA_PAGO_REAL >= '2025-01-01'
    )
    WHERE RN = 1
  )

  UNION ALL

  SELECT DISTINCT
    'CUENTA_COBRO' AS FUENTE,
    CAST(fecha_emision AS TIMESTAMP) AS FECHA_TRANSACCION,
    codigo_tipo_identificacion_emisor AS TIPO_DOCUMENTO_PROVEEDOR,
    razon_social_emisor AS NOMBRE_PROVEEDOR,
    CAST(key_id_emisor AS STRING) AS KEY_ID_PROVEEDOR,
    codigo_iso_moneda AS MONEDA,
    numero_documento AS ORDEN_FACTURA,
    CAST(razon_social_cia AS STRING) AS COMPANIA,
    CAST((valor_base + IFNULL(valor_iva, 0)) AS NUMERIC) AS VALOR_TRANSACCION,
    CAST(NULL AS STRING) AS FECHA_ESTADO_PROCESO
  FROM `sb-ecosistemaanalitico-lago.seguros_bolivar.cuentas_de_cobro_proveedores`
),

base AS (
  SELECT DISTINCT
    CAST(bp.COMPANIA AS STRING) AS nit_compania,
    COALESCE(hc.COMPANIA_HOMOLOGADA, CAST(bp.COMPANIA AS STRING)) AS compania_homologada,
    bp.FUENTE,
    bp.ORDEN_FACTURA AS nro_factura,
    bp.FECHA_TRANSACCION,
    bp.TIPO_DOCUMENTO_PROVEEDOR AS tip_doc_proveedor,
    bp.KEY_ID_PROVEEDOR AS key_id_proveedor,
    bp.VALOR_TRANSACCION,
    bp.FECHA_ESTADO_PROCESO AS fecha_estado_proceso
  FROM base_proveedores bp
  LEFT JOIN homologacion_compania hc
    ON TRIM(CAST(bp.COMPANIA AS STRING)) = TRIM(hc.COMPANIA_ORIGINAL)
  WHERE bp.KEY_ID_PROVEEDOR IS NOT NULL
),

historia_proveedor AS (
  SELECT
    nit_compania,
    compania_homologada,
    FUENTE,
    nro_factura,
    FECHA_TRANSACCION,
    tip_doc_proveedor,
    key_id_proveedor,
    VALOR_TRANSACCION,
    fecha_estado_proceso,

    COUNT(*) OVER (
      PARTITION BY key_id_proveedor, compania_homologada, FUENTE
      ORDER BY FECHA_TRANSACCION
      ROWS BETWEEN UNBOUNDED PRECEDING AND 1 PRECEDING
    ) AS cantidad_pagos_previos,

    AVG(VALOR_TRANSACCION) OVER (
      PARTITION BY key_id_proveedor, compania_homologada, FUENTE
      ORDER BY FECHA_TRANSACCION
      ROWS BETWEEN UNBOUNDED PRECEDING AND 1 PRECEDING
    ) AS promedio_historico_previo,

    STDDEV_SAMP(VALOR_TRANSACCION) OVER (
      PARTITION BY key_id_proveedor, compania_homologada, FUENTE
      ORDER BY FECHA_TRANSACCION
      ROWS BETWEEN UNBOUNDED PRECEDING AND 1 PRECEDING
    ) AS desviacion_estandar_previa
  FROM base
),

resultado_final AS (
  SELECT
    nit_compania,
    compania_homologada,
    FUENTE,
    nro_factura,
    DATE(FECHA_TRANSACCION) AS fecha_emision,
    tip_doc_proveedor,
    key_id_proveedor,
    VALOR_TRANSACCION AS valor_transaccion,
    cantidad_pagos_previos,
    promedio_historico_previo,
    desviacion_estandar_previa,
    promedio_historico_previo + (3 * desviacion_estandar_previa) AS umbral_transaccional,
    fecha_estado_proceso,
    FORMAT_DATE('%Y-%m', CURRENT_DATE()) AS FECHA_ALERTA_MES,
    CURRENT_DATE() AS FECHA_ALERT
  FROM historia_proveedor
),

filtrado AS (
  SELECT *
  FROM resultado_final
  WHERE cantidad_pagos_previos >= 2
    AND valor_transaccion > umbral_transaccional
),

priorizado AS (
  SELECT
    *
  FROM filtrado
  QUALIFY ROW_NUMBER() OVER (
    PARTITION BY key_id_proveedor, FECHA_ALERTA_MES
    ORDER BY
      valor_transaccion DESC,
      fecha_emision DESC,
      CASE
        WHEN FUENTE = 'COUPA' THEN 1
        WHEN FUENTE = 'FACTURA_ELECTRONICA' THEN 2
        WHEN FUENTE = 'ORDEN_PAGO' THEN 3
        WHEN FUENTE = 'CUENTA_COBRO' THEN 4
        ELSE 99
      END
  ) = 1
)

SELECT
    p.nit_compania,
    p.compania_homologada,
    p.FUENTE AS fuente,
    p.nro_factura,
    p.fecha_emision,
    p.tip_doc_proveedor,
    p.key_id_proveedor,
    p.valor_transaccion,
    p.cantidad_pagos_previos,
    p.promedio_historico_previo,
    p.desviacion_estandar_previa,
    p.umbral_transaccional,
    p.fecha_estado_proceso,
    p.FECHA_ALERTA_MES,
    p.FECHA_ALERT
FROM priorizado p

WHERE p.fecha_emision >= DATE '2026-03-01'
  AND NOT (p.compania_homologada = "Seguros Comerciales Bolívar" AND p.fuente = "ORDEN_PAGO")
  AND NOT  (p.compania_homologada = "Seguros Bolívar" AND p.fuente = "ORDEN_PAGO")
  -- 🔥 CONTROL DE DUPLICADOS
  AND NOT EXISTS (
    SELECT 1
    FROM `sb-ecosistemaanalitico-lago.cumplimiento_normativo_prod.PROV_0001` t
    WHERE t.key_id_proveedor = p.key_id_proveedor
      AND t.fuente = p.fuente
      AND t.FECHA_ALERT = p.FECHA_ALERT
  );
