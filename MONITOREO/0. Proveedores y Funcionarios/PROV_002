    c.NOMBRE_LUGAR_NACIMIENTO,
    c.FECHA_MODIFICACION,
    FORMAT_DATE('%Y-%m', CURRENT_DATE()) AS FECHA_ALERTA_MES,
    CURRENT_DATE() AS FECHA_ALERTA
  FROM base_homologada b
  LEFT JOIN clientes c
    ON b.tip_doc_proveedor = c.TIPO_DOCUMENTO
   AND b.key_id_proveedor = c.KEY_ID
  WHERE c.FECHA_MODIFICACION IS NOT NULL
    AND DATE(c.FECHA_MODIFICACION) < DATE_SUB(CURRENT_DATE(), INTERVAL 1 YEAR)
    AND b.fecha_emision_factura >= DATE '2026-03-01'
),

numeradas AS (
  SELECT
    *,
    ROW_NUMBER() OVER (
      PARTITION BY tip_doc_proveedor, key_id_proveedor
      ORDER BY
        fecha_emision_factura DESC,
        vlr_total_factura DESC,
        CASE
          WHEN fuente = 'COUPA' THEN 1
          WHEN fuente = 'FACTURA_ELECTRONICA' THEN 2
          WHEN fuente = 'ORDEN_PAGO' THEN 3
          WHEN fuente = 'CUENTA_COBRO' THEN 4
          ELSE 99
        END
    ) AS rn
  FROM resultado
)

SELECT
  nit_compania,
  compania_homologada,
  fuente,
  nro_factura,
  fecha_emision_factura,
  tip_doc_proveedor,
  key_id_proveedor,
  vlr_total_factura,
  fecha_estado_proceso,
  ACTIVIDAD_ECONOMICA,
  CODIGO_CIIU,
  CODIGO_LUGAR_NACIMIENTO,
  NOMBRE_LUGAR_NACIMIENTO,
  FECHA_MODIFICACION,
  FECHA_ALERTA_MES,
  FECHA_ALERTA
FROM numeradas n
WHERE rn = 1
  AND NOT (compania_homologada = "Seguros Comerciales Bolívar" AND fuente = "ORDEN_PAGO")
  AND NOT (compania_homologada = "Seguros Bolívar" AND fuente = "ORDEN_PAGO")
  AND NOT (compania_homologada = "Capitalizadora Bolívar" AND fuente = "ORDEN_PAGO")
  AND NOT (compania_homologada = "Seguros Comerciales Bolívar" AND fuente = "FACTURA_ELECTRONICA")
  AND NOT (compania_homologada = "Seguros Bolívar" AND fuente = "FACTURA_ELECTRONICA")

  AND NOT EXISTS (
    SELECT 1
    FROM `sb-ecosistemaanalitico-lago.cumplimiento_normativo_prod.PROV_0002` t
    WHERE t.tip_doc_proveedor = n.tip_doc_proveedor
      AND t.key_id_proveedor = n.key_id_proveedor
      AND EXTRACT(YEAR FROM t.FECHA_ALERTA) = EXTRACT(YEAR FROM n.FECHA_ALERTA)
  )

ORDER BY fecha_emision_factura DESC, vlr_total_factura DESC;













