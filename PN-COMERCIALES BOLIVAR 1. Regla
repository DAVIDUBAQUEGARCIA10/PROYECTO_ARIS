WITH alertas_filtradas AS (

    SELECT
        NUMERO_POLIZA,
        KEY_ID_TOMADOR,
        TIPO_DOCUMENTO_TOMADOR,
        ANO_MES,
        Justificacion_Anomalia,
        anomaly_score,

        CAST(
            FLOOR(SAFE_CAST(NUMERO_POLIZA AS INT64) / 100)
            AS INT64
        ) AS NUMERO_CUENTA_FONDO_ALERTA

    FROM `sb-sandbox-usuarios.sandbox_cumplimiento.alertas_clave_com_pn`

    WHERE ANO_MES = (
        SELECT MAX(ANO_MES)
        FROM `sb-sandbox-usuarios.sandbox_cumplimiento.alertas_clave_com_pn`
    )

    AND causa_principal != 'Comportamiento normal'
),

aportes_extraordinarios AS (

    SELECT
        NUMERO_CUENTA_FONDO,
        VALOR_TRANSACCION,
        FECHA_APLICACION,
        CODIGO_COMPANIA

    FROM `sb-ecosistemaanalitico-lago.seguros_bolivar.t_aportes_extraordinarios`

    WHERE FECHA_PROCESO >= '2026-03-01'
),

polizas_objetivo AS (

    SELECT DISTINCT NUMERO_POLIZA

    FROM alertas_filtradas
),

polizas_recientes AS (

    SELECT
        p.CODIGO_COMPANIA,
        p.NUMERO_POLIZA,
        p.NOMBRE_PRODUCTO AS NOMBRE_PRODUCTO_POLIZA,
        p.MARCA_ANULACION,
        p.FECHA_PROCESO

    FROM `sb-ecosistemaanalitico-lago.seguros_bolivar.t_polizas_riesgos_endosos` p

    INNER JOIN polizas_objetivo o

        ON SAFE_CAST(p.NUMERO_POLIZA AS STRING)
        =
        SAFE_CAST(o.NUMERO_POLIZA AS STRING)

    QUALIFY ROW_NUMBER() OVER (

        PARTITION BY p.NUMERO_POLIZA

        ORDER BY p.FECHA_PROCESO DESC

    ) = 1
)

SELECT

    p.CODIGO_COMPANIA,

    a.TIPO_DOCUMENTO_TOMADOR,

    a.NUMERO_POLIZA,

    a.KEY_ID_TOMADOR,

    t.VALOR_TRANSACCION,

    t.FECHA_APLICACION,

    p.NOMBRE_PRODUCTO_POLIZA,

    a.ANO_MES,

    a.anomaly_score,

    a.Justificacion_Anomalia

FROM alertas_filtradas a

INNER JOIN aportes_extraordinarios t

    ON a.NUMERO_CUENTA_FONDO_ALERTA
    =
    SAFE_CAST(t.NUMERO_CUENTA_FONDO AS INT64)

INNER JOIN polizas_recientes p

    ON SAFE_CAST(a.NUMERO_POLIZA AS STRING)
    =
    SAFE_CAST(p.NUMERO_POLIZA AS STRING)

WHERE p.MARCA_ANULACION != 'S'

AND t.VALOR_TRANSACCION >= 3056841

QUALIFY ROW_NUMBER() OVER (

    PARTITION BY
        a.KEY_ID_TOMADOR,
        a.TIPO_DOCUMENTO_TOMADOR,
        a.ANO_MES

    ORDER BY
        t.VALOR_TRANSACCION DESC,
        t.FECHA_APLICACION DESC

) = 1

ORDER BY
    a.KEY_ID_TOMADOR,
    a.TIPO_DOCUMENTO_TOMADOR,
    a.ANO_MES;
