INSERT INTO `sb-ecosistemaanalitico-lago.cumplimiento_normativo_prod.IPS_0005`
(
  nit_compania,
  nro_factura,
  fecha_emision,
  tip_doc_proveedor,
  key_id_proveedor,
  vlr_total_factura,
  fecha_estado_proceso,
  umbral_transaccional,
  FECHA_ALERTA_MES,
  FECHA_ALERTA
)

WITH umbral AS (
  SELECT 29559700 AS umbral_percentil_95_empresa
),

base AS (
  SELECT
    f.nit_compania,
    f.nro_factura,
    DATE(f.fec_emision_factura) AS fecha_emision,
    FORMAT_DATE('%Y-%m', DATE(f.fec_emision_factura)) AS periodo_mes,
    f.tip_doc_proveedor,
    f.key_id_proveedor,
    f.vlr_total_factura,
    f.fecha_estado_proceso,
    u.umbral_percentil_95_empresa AS umbral_transaccional,
    FORMAT_DATE('%Y-%m', CURRENT_DATE()) AS FECHA_ALERTA_MES,
    CURRENT_DATE() AS FECHA_ALERTA
  FROM `sb-ecosistemaanalitico-lago.seguros_bolivar.evento_factura_electronica` f
  CROSS JOIN umbral u
  WHERE f.nit_compania = 901267811
    AND DATE(f.fec_emision_factura) >= DATE '2026-03-01'
    AND f.tip_doc_proveedor IN ('NT', 'NE')
    AND f.vlr_total_factura > u.umbral_percentil_95_empresa
),

numeradas AS (
  SELECT *,
         ROW_NUMBER() OVER (
           PARTITION BY tip_doc_proveedor, key_id_proveedor, periodo_mes
           ORDER BY fecha_emision DESC, vlr_total_factura DESC
         ) AS rn
  FROM base
)

SELECT
  nit_compania,
  nro_factura,
  fecha_emision,
  tip_doc_proveedor,
  key_id_proveedor,
  vlr_total_factura,
  fecha_estado_proceso,
  umbral_transaccional,
  FECHA_ALERTA_MES,
  FECHA_ALERTA
FROM numeradas
WHERE rn = 1
  AND NOT EXISTS (
    SELECT 1
    FROM `sb-ecosistemaanalitico-lago.cumplimiento_normativo_prod.IPS_0005` t
    WHERE t.tip_doc_proveedor = numeradas.tip_doc_proveedor
      AND t.key_id_proveedor = numeradas.key_id_proveedor
      AND t.fecha_emision = numeradas.fecha_emision
      AND t.nro_factura = numeradas.nro_factura
  );
