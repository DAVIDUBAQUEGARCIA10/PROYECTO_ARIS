-- INSERTAR REGISTROS DE TOMADORES CON RECAUDOS ALTOS POR CAJA O RECAUDO EMPRESARIAL
INSERT INTO sb-ecosistemaanalitico-lago.cumplimiento_normativo_prod.com_0103_prod (
    CODIGO_COMPANIA, 
    CODIGO_RAMO_EMISION, 
    CODIGO_PRODUCTO, 
    CODIGO_LOCALIDAD, 
    NUMERO_POLIZA, 
    FECHA_EMISION_POLIZA, 
    FECHA_VIGENCIA_POLIZA, 
    FECHA_VENCIMIENTO_POLIZA, 
    FECHA_CANCELACION_POLIZA, 
    CODIGO_FORMA_COBRO, 
    FORMA_COBRO, 
    TIPO_DOCUMENTO_TOMADOR, 
    KEY_ID_TOMADOR, 
    VALOR_RECAUDO_MES, 
    FECHA_RECAUDO, 
    VALOR_AHORRO_EXTRA,
    FECHA_ALERTA_MES,
    FECHA_ALERTA,
    NUMEROS_POLIZA_LISTA,
    CODIGOS_RAMO_EMISION_LISTA
)

WITH TercerosConPagosCaja AS (
    SELECT 
        KEY_ID_TOMADOR
    FROM 
        sb-ecosistemaanalitico-lago.datamart.t_produccion_recaudo_diario
    WHERE 
        FECHA_RECAUDO >= '2026-03-01'
        AND FECHA_CARGUE >= '2026-03-01'
        --AND FORMA_COBRO IN ('CAJA', 'RECAUDO EMPRESARIAL')
        AND CODIGO_COMPANIA = 3
        AND CAST(FECHA_VENCIMIENTO_POLIZA AS DATE) >= CURRENT_DATE()
    GROUP BY 
        KEY_ID_TOMADOR
    HAVING 
        COUNT(DISTINCT NUMERO_POLIZA) > 2
        AND COUNT(DISTINCT CODIGO_RAMO_EMISION) > 2
),

ListasPorTomador AS (
    SELECT
        KEY_ID_TOMADOR,
        STRING_AGG(DISTINCT CAST(NUMERO_POLIZA AS STRING), ', ' ORDER BY CAST(NUMERO_POLIZA AS STRING)) AS NUMEROS_POLIZA_LISTA,
        STRING_AGG(DISTINCT CAST(CODIGO_RAMO_EMISION AS STRING), ', ' ORDER BY CAST(CODIGO_RAMO_EMISION AS STRING)) AS CODIGOS_RAMO_EMISION_LISTA
    FROM sb-ecosistemaanalitico-lago.datamart.t_produccion_recaudo_diario
    WHERE 
        FECHA_RECAUDO >= '2026-03-01'
        AND FECHA_CARGUE >= '2026-03-01'
        --AND FORMA_COBRO IN ('CAJA', 'RECAUDO EMPRESARIAL')
        AND CODIGO_COMPANIA = 3
        AND KEY_ID_TOMADOR IN (SELECT KEY_ID_TOMADOR FROM TercerosConPagosCaja)
    GROUP BY KEY_ID_TOMADOR
),

PagosConAlerta AS (
    SELECT 
        p.*,
        l.NUMEROS_POLIZA_LISTA,
        l.CODIGOS_RAMO_EMISION_LISTA,
        ROW_NUMBER() OVER (PARTITION BY p.KEY_ID_TOMADOR ORDER BY p.FECHA_RECAUDO DESC) AS rn
    FROM 
        sb-ecosistemaanalitico-lago.datamart.t_produccion_recaudo_diario p
    JOIN ListasPorTomador l ON p.KEY_ID_TOMADOR = l.KEY_ID_TOMADOR
    WHERE 
        p.FECHA_RECAUDO >= '2026-03-01'
        AND p.FECHA_CARGUE >= '2026-03-01'
        --AND p.FORMA_COBRO IN ('CAJA', 'RECAUDO EMPRESARIAL')
        AND p.VALOR_RECAUDO_MES > 1000
        AND p.CODIGO_COMPANIA = 3
        AND CAST(p.FECHA_VENCIMIENTO_POLIZA AS DATE) >= CURRENT_DATE()
        AND p.KEY_ID_TOMADOR IN (SELECT KEY_ID_TOMADOR FROM TercerosConPagosCaja)
)

SELECT 
    CODIGO_COMPANIA, 
    CODIGO_RAMO_EMISION, 
    CODIGO_PRODUCTO, 
    CODIGO_LOCALIDAD, 
    NUMERO_POLIZA, 
    FECHA_EMISION_POLIZA, 
    FECHA_VIGENCIA_POLIZA, 
    FECHA_VENCIMIENTO_POLIZA, 
    FECHA_CANCELACION_POLIZA, 
    CODIGO_FORMA_COBRO, 
    FORMA_COBRO, 
    TIPO_DOCUMENTO_TOMADOR, 
    KEY_ID_TOMADOR, 
    VALOR_RECAUDO_MES, 
    FECHA_RECAUDO, 
    VALOR_AHORRO_EXTRA,
    FORMAT_DATE('%Y-%m', CURRENT_DATE()) AS FECHA_ALERTA_MES,
    CURRENT_DATE() AS FECHA_ALERTA,
    NUMEROS_POLIZA_LISTA,
    CODIGOS_RAMO_EMISION_LISTA
FROM PagosConAlerta
WHERE rn = 1
  AND NOT EXISTS (
      SELECT 1
      FROM sb-ecosistemaanalitico-lago.cumplimiento_normativo_prod.com_0103_prod t
      WHERE 
          t.KEY_ID_TOMADOR = PagosConAlerta.KEY_ID_TOMADOR
          AND t.NUMERO_POLIZA = PagosConAlerta.NUMERO_POLIZA
  );-- INSERTAR REGISTROS DE TOMADORES CON RECAUDOS ALTOS POR CAJA O RECAUDO EMPRESARIAL
