SELECT distinct 

  c.*,
  r.CODIGO_RESTRICCION,
  r.DESCRIPCION AS DESCRIPCION_RESTRICCION,
  r.FECHA_CREACION AS FECHA_CREACION_RESTRICCION,
  FORMAT_DATE('%Y-%m', CURRENT_DATE()) AS FECHA_ALERTA_MES,  # Mes de generación de la alerta en formato YYYY-MM
  CURRENT_DATE() AS FECHA_ALERTA  # Fecha actual como fecha de generación de la alerta

FROM COLABORADORES c
LEFT JOIN RESTRINGIDOS_ACTIVOS r
  ON r.KEY_ID = c.KEY_ID
 AND r.TIPO_DOCUMENTO_TERCERO = c.TIPO_DOCUMENTO
where CODIGO_RESTRICCION is not null
AND NOT EXISTS (
  SELECT 1
  FROM `sb-ecosistemaanalitico-lago.cumplimiento_normativo_prod.funcionarios_restringidos` t
  WHERE t.TIPO_DOCUMENTO = c.TIPO_DOCUMENTO
    AND t.KEY_ID = c.KEY_ID
    AND t.CODIGO_RESTRICCION = r.CODIGO_RESTRICCION
);
