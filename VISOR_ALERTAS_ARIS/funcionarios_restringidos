RESTRINGIDOS_ACTIVOS AS (
  SELECT distinct 
    TIPO_DOCUMENTO_TERCERO,
    KEY_ID,
    CODIGO_RESTRICCION,
    DESCRIPCION,
    FECHA_BAJA,
    FECHA_CREACION,
