INSERT INTO `sb-ecosistemaanalitico-lago.cumplimiento_normativo_prod.seg_0002_prod`
(
    CODIGO_COMPANIA,
    TIPO_DOCUMENTO,
    KEY_ID_TOMADOR,
    NUMERO_POLIZA,
    CODIGO_RAMO_CONTABLE,
    CODIGO_PRODUCTO,
    CODIGO_LOCALIDAD,
    VALOR_RETIRO,
    VALOR_GIRADO,
    ESTADO_REGISTRO,
    ESTADO_GIRO,
    ORDEN_PAGO,
    FECHA_ULT_MODIFICACION,
    FECHA_EMISION_POLIZA,
    FECHA_EMISION_ENDOSO,
    FECHA_FIN_POLIZA,
    MCA_ANULACION_POLIZA,
    FECHA_ALERTA_MES,
    FECHA_ALERTA
)
WITH ranked_data AS (
    SELECT
        CODIGO_COMPANIA,
        TIPO_DOCUMENTO,
        KEY_ID_TOMADOR,
        NUMERO_POLIZA,
        CODIGO_RAMO_CONTABLE,
        CODIGO_PRODUCTO,
        CODIGO_LOCALIDAD,
        ROUND(VALOR_RETIRO, 0) AS VALOR_RETIRO,  -- ✅ Elimina decimales fantasma
        ROUND(VALOR_GIRADO, 0) AS VALOR_GIRADO,
        ESTADO_REGISTRO,
        ESTADO_GIRO,
        ORDEN_PAGO,
        FECHA_ULT_MODIFICACION,
        FECHA_EMISION_POLIZA,
        FECHA_EMISION_ENDOSO,
        FECHA_FIN_POLIZA,
        MCA_ANULACION_POLIZA,
        ROW_NUMBER() OVER (
          PARTITION BY KEY_ID_TOMADOR, TIPO_DOCUMENTO, ROUND(VALOR_RETIRO, 0)  -- ✅ Consistente con el redondeo
          ORDER BY FECHA_ULT_MODIFICACION DESC
        ) AS rn
    FROM `sb-ecosistemaanalitico-lago.seguros_bolivar.t_ordenes_pago_vida_retiros`
    WHERE
        VALOR_RETIRO > 25000000
        AND CODIGO_COMPANIA = 2
        AND DATE(FECHA_ULT_MODIFICACION) < DATE(FECHA_FIN_POLIZA)
        AND DATE(FECHA_ULT_MODIFICACION) <= DATE_ADD(DATE(FECHA_EMISION_POLIZA), INTERVAL 90 DAY)
        AND DATE(FECHA_FIN_POLIZA) >= CURRENT_DATE()
        AND FECHA_ULT_MODIFICACION >= '2026-03-01'
)
SELECT
    f.CODIGO_COMPANIA,
    f.TIPO_DOCUMENTO,
    f.KEY_ID_TOMADOR,
    f.NUMERO_POLIZA,
    f.CODIGO_RAMO_CONTABLE,
    f.CODIGO_PRODUCTO,
    f.CODIGO_LOCALIDAD,
    f.VALOR_RETIRO,
    f.VALOR_GIRADO,
    f.ESTADO_REGISTRO,
    f.ESTADO_GIRO,
    f.ORDEN_PAGO,
    f.FECHA_ULT_MODIFICACION,
    f.FECHA_EMISION_POLIZA,
    f.FECHA_EMISION_ENDOSO,
    f.FECHA_FIN_POLIZA,
    f.MCA_ANULACION_POLIZA,
    FORMAT_DATE('%Y-%m', CURRENT_DATE()) AS FECHA_ALERTA_MES,
    CURRENT_DATE() AS FECHA_ALERTA
FROM ranked_data f
LEFT JOIN `sb-ecosistemaanalitico-lago.cumplimiento_normativo_prod.seg_0002_prod` existing
    ON f.KEY_ID_TOMADOR = existing.KEY_ID_TOMADOR
    AND f.NUMERO_POLIZA = existing.NUMERO_POLIZA
    AND f.VALOR_RETIRO = existing.VALOR_RETIRO 
    and f.FECHA_ULT_MODIFICACION = existing.FECHA_ULT_MODIFICACION -- ✅ Ya ambos lados serían valores redondeados
WHERE f.rn = 1
  AND existing.KEY_ID_TOMADOR IS NULL;
